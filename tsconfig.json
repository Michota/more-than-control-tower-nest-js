{
    "compilerOptions": {
        "strict": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "resolvePackageJsonExports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2023",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": true,
        "strictBindCallApply": true,
        "noFallthroughCasesInSwitch": true,

        "paths": {
            // `dist/*` is added to support running the compiled code without needing to change the import paths
            "@src/*": ["src/*", "dist/*"],
            "@modules/*": ["src/modules/*", "dist/modules/*"],
            "@config/*": ["src/config/*", "dist/config/*"],
            "@libs/*": ["src/libs/*", "dist/libs/*"],
            "@tests/*": ["tests/*"]
        }
    },

    "exclude": [".kanelrc.js", "node_modules", "dist"]
}
